classDiagram
    class User {
        +UUID id
        +String fullName
        +String email
        +String passwordHash
        +Enum role [admin, teacher, student]
        +String avatar
        +String phone
        +Date dateOfBirth
        +String gender
        +String address
        +Boolean isActive
        +DateTime createdAt
        +login()
        +logout()
        +changePassword()
        +updateProfile()
    }

    class Class {
        +UUID id
        +String name
        +String gradeLevel
        +String academicYear
        +String description
        +Boolean isActive
        +DateTime createdAt
        +addStudent()
        +removeStudent()
    }

    class Subject {
        +UUID id
        +String name
        +String code
        +String description
        +String thumbnail
        +Boolean isActive
        +DateTime createdAt
    }

    class CourseEnrollment {
        +UUID id
        +UUID teacherId
        +UUID subjectId
        +UUID classId
        +String semester
        +String academicYear
        +Boolean isActive
        +DateTime createdAt
        +getLessons()
        +getAssignments()
    }

    class Lesson {
        +UUID id
        +UUID courseEnrollmentId
        +String title
        +String content
        +String fileUrl
        +String videoUrl
        +Int orderIndex
        +Boolean isPublished
        +DateTime publishedAt
        +publish()
        +unpublish()
    }

    class Assignment {
        +UUID id
        +UUID courseEnrollmentId
        +String title
        +String description
        +Enum type [quiz, essay, file]
        +DateTime dueDate
        +DateTime startDate
        +Int timeLimitMinutes
        +Decimal totalPoints
        +Int maxAttempts
        +Boolean shuffleQuestions
        +Boolean showResultImmediately
        +Boolean isPublished
        +publish()
        +addQuestion()
        +removeQuestion()
    }

    class Question {
        +UUID id
        +UUID assignmentId
        +String questionText
        +Enum questionType [single_choice, multiple_choice, true_false]
        +Decimal points
        +Int orderIndex
        +String explanation
        +addOption()
        +setCorrectAnswer()
    }

    class AnswerOption {
        +UUID id
        +UUID questionId
        +String optionText
        +Boolean isCorrect
        +Int orderIndex
    }

    class Submission {
        +UUID id
        +UUID assignmentId
        +UUID studentId
        +Int attemptNumber
        +String essayContent
        +String fileUrl
        +DateTime startedAt
        +DateTime submittedAt
        +Decimal score
        +String feedback
        +UUID gradedBy
        +DateTime gradedAt
        +Enum status [in_progress, submitted, graded, late]
        +submitEssay()
        +submitQuiz()
        +autoGrade()
    }

    class StudentAnswer {
        +UUID id
        +UUID submissionId
        +UUID questionId
        +String selectedOptionIds
        +Boolean isCorrect
        +Decimal pointsEarned
    }

    class StudentClass {
        +UUID id
        +UUID studentId
        +UUID classId
        +DateTime joinedAt
    }

    class Announcement {
        +UUID id
        +UUID courseEnrollmentId
        +UUID authorId
        +String title
        +String content
        +Boolean isGlobal
        +DateTime createdAt
    }

    class Comment {
        +UUID id
        +UUID lessonId
        +UUID authorId
        +String content
        +UUID parentId
        +DateTime createdAt
    }

    class Notification {
        +UUID id
        +UUID userId
        +String title
        +String message
        +String type
        +UUID referenceId
        +Boolean isRead
        +DateTime createdAt
        +markRead()
    }

    %% Relationships
    User "1" --> "0..*" StudentClass : enrolled in
    User "1" --> "0..*" CourseEnrollment : teaches
    User "1" --> "0..*" Submission : submits
    User "1" --> "0..*" Comment : writes
    User "1" --> "0..*" Notification : receives
    User "1" --> "0..*" Announcement : creates

    Class "1" --> "0..*" StudentClass : has
    Class "1" --> "0..*" CourseEnrollment : has

    Subject "1" --> "0..*" CourseEnrollment : has

    CourseEnrollment "1" --> "0..*" Lesson : contains
    CourseEnrollment "1" --> "0..*" Assignment : contains
    CourseEnrollment "1" --> "0..*" Announcement : has

    Assignment "1" --> "0..*" Question : contains
    Assignment "1" --> "0..*" Submission : receives

    Question "1" --> "0..*" AnswerOption : has
    Question "1" --> "0..*" StudentAnswer : answered by

    Submission "1" --> "0..*" StudentAnswer : contains

    Lesson "1" --> "0..*" Comment : has
